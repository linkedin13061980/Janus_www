---
import { localePath } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  order: number;
  titre: string;
  desc: string;
  items: string[];
  cta: string;
  href: string;
  badge?: string;
  alternate?: boolean;
}

const { locale, order, titre, desc, items, cta, href, badge, alternate = false } = Astro.props;
const num = String(order).padStart(2, '0');
const fullHref = localePath(locale, href);
---

<section class={`py-24 px-6 border-t border-gold/10 ${alternate ? 'bg-anthracite-light' : ''}`}>
  <div class="max-w-3xl mx-auto">
    <p class="text-gold/50 text-xs uppercase tracking-widest mb-2">{num}</p>

    <div class="flex flex-wrap items-center gap-3 mb-6">
      <h2 class="text-4xl font-serif font-light text-white leading-tight">{titre}</h2>
      {badge && (
        <span class="text-xs px-3 py-1 border border-gold/40 text-gold uppercase tracking-wider">{badge}</span>
      )}
    </div>

    <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">{desc}</p>

    <ul class="space-y-4 mb-12">
      {items.map(item => (
        <li class="flex gap-4 text-white/55 text-sm">
          <span class="text-gold shrink-0 mt-0.5">◆</span>
          {item}
        </li>
      ))}
    </ul>

    <a
      href={fullHref}
      class="inline-block px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm"
    >
      {cta}
    </a>
  </div>
</section>
