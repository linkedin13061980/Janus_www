---
interface Props {
  eyebrow: string;
  headline: string;
  subheadline: string;
  cta: {
    label: string;
    href: string;
  };
}

const { eyebrow, headline, subheadline, cta } = Astro.props;
---

<section class="pt-40 pb-24 px-6 border-b border-gold/10">
  <div class="max-w-3xl mx-auto">
    <p class="text-gold/50 text-xs uppercase tracking-widest mb-6">{eyebrow}</p>
    <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-tight mb-8 whitespace-pre-line">
      {headline}
    </h1>
    <p class="text-white/50 text-lg leading-relaxed max-w-xl mb-12">
      {subheadline}
    </p>
    <a
      href={cta.href}
      class="inline-block px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm"
    >
      {cta.label}
    </a>
  </div>
</section>
