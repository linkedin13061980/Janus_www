---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';

const locale = 'en';
const currentPath = '/contact';
---

<Layout
  title="Contact — JANUS Linguistic Agency | Lyon"
  description="Contact JANUS Linguistic Agency for a personalised quote. Training, interpreting, on-site support and translation in French-Polish, Lyon."
  locale={locale}
  currentPath={currentPath}
>
  <section class="py-20 max-w-4xl mx-auto px-4">
    <div class="text-center mb-14">
      <p class="text-gold text-sm uppercase tracking-widest mb-3">Let's talk about your project</p>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-6">Contact us</h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Response guaranteed within 24 business hours. Every enquiry is reviewed personally.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-14">
      <a href="tel:+33967056831" class="flex items-center gap-3 p-4 border border-gold/20 hover:border-gold/50 transition-colors group">
        <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <div>
          <p class="text-xs text-white/40 uppercase tracking-wider">Phone</p>
          <p class="text-white/80 text-sm group-hover:text-gold transition-colors">+33 9 67 05 68 31</p>
        </div>
      </a>
      <a href="mailto:contact@agence-janus.fr" class="flex items-center gap-3 p-4 border border-gold/20 hover:border-gold/50 transition-colors group">
        <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <div>
          <p class="text-xs text-white/40 uppercase tracking-wider">Email</p>
          <p class="text-white/80 text-sm group-hover:text-gold transition-colors">contact@agence-janus.fr</p>
        </div>
      </a>
      <div class="flex items-center gap-3 p-4 border border-gold/20">
        <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <div>
          <p class="text-xs text-white/40 uppercase tracking-wider">Address</p>
          <p class="text-white/80 text-sm">Lyon, France</p>
        </div>
      </div>
    </div>

    <ContactForm locale={locale} />
  </section>
</Layout>
