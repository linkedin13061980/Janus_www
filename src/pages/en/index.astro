---
import Layout from '../../layouts/Layout.astro';
const locale = 'en';
const currentPath = '/';

const marches = [
  { flag: '🇵🇱', pays: 'Poland',         label: 'Priority',       href: '/en/marches/pologne',     featured: true  },
  { flag: '🇬🇧', pays: 'United Kingdom', label: 'Business',       href: '/en/marches/royaume-uni', featured: false },
  { flag: '🇩🇪', pays: 'Germany',        label: 'DACH Zone',      href: '/en/marches/allemagne',   featured: false },
  { flag: '🇪🇸', pays: 'Spain',          label: 'Hispanic',       href: '/en/marches/espagne',     featured: false },
  { flag: '🇮🇹', pays: 'Italy',          label: 'Franco-Italian', href: '/en/marches/italie',      featured: false },
  { flag: '🇫🇷', pays: 'France',         label: 'FLE · Allophones',href: '/en/langues#fle',        featured: false },
];

const services = [
  { icon: '🎓', titre: 'Training',        desc: 'Tailored programmes for managers, sales teams and technicians. CPF/OPCO funding available.', href: '/en/services' },
  { icon: '🎙️', titre: 'Interpreting',    desc: 'Native interpreters for negotiations, audits and sensitive meetings. NDA signed before each assignment.', href: '/en/services' },
  { icon: '🤝', titre: 'On-site support', desc: 'Physical presence during critical missions. Supplier audits, negotiations, trade shows.', href: '/en/services' },
  { icon: '📄', titre: 'Translation',     desc: 'Legal, technical, commercial, financial. Native translators by field. Quote within 2h.', href: '/en/services' },
];

const stats = [
  { num: '25', unit: ' yrs',    label: 'in international finance' },
  { num: '6',  unit: ' lang',   label: '100% native specialists'  },
  { num: '40', unit: 'h',       label: 'mission → signed contract' },
  { num: 'NDA', unit: '',       label: 'before each assignment'   },
];
---

<Layout
  title="JANUS — Your international exchanges, secured | Lyon"
  description="Linguistic and intercultural expert for your international exchanges. Training, interpreting, on-site support, translation. Qualiopi certified. Lyon."
  locale={locale}
  currentPath={currentPath}
>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />
  <style is:global>
    .hp-serif{font-family:'Cormorant Garamond',Georgia,serif}
    .hp-sans{font-family:'DM Sans',system-ui,sans-serif}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.in{opacity:1;transform:none}
    .stagger>*{opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease}
    .stagger.in>*:nth-child(1){opacity:1;transform:none;transition-delay:.05s}
    .stagger.in>*:nth-child(2){opacity:1;transform:none;transition-delay:.15s}
    .stagger.in>*:nth-child(3){opacity:1;transform:none;transition-delay:.25s}
    .stagger.in>*:nth-child(4){opacity:1;transform:none;transition-delay:.35s}
    .stagger.in>*:nth-child(5){opacity:1;transform:none;transition-delay:.45s}
    .stagger.in>*:nth-child(6){opacity:1;transform:none;transition-delay:.55s}
    .tile{transition:transform .2s ease,box-shadow .2s ease}
    .tile:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.10)}
    @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .ticker-inner{display:flex;width:max-content;animation:ticker 22s linear infinite}
  </style>

  <section style="background:#f7f5f2" class="pt-36 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.45em] mb-8 reveal" style="color:#b5936b">Lyon · Qualiopi · NDA systematic</p>
      <h1 class="hp-serif text-5xl md:text-6xl font-light leading-[1.05] mb-6 reveal" style="color:#1a1a1a">
        Where would you like<br/><em class="italic" style="color:#b5936b">to expand?</em>
      </h1>
      <p class="hp-sans text-lg mb-14 max-w-lg leading-[1.8] reveal" style="color:rgba(26,26,26,0.5)">
        Choose your target market — JANUS handles the linguistic and intercultural dimension of your mission.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 stagger">
        {marches.map(m => (
          <a href={m.href} class={`tile block p-6 md:p-8 border ${m.featured ? 'border-[#b5936b] bg-[#1a1a1a]' : 'border-[#1a1a1a]/12 bg-white hover:border-[#b5936b]/60'}`}>
            <span class="text-4xl md:text-5xl block mb-4 leading-none">{m.flag}</span>
            <p class={`hp-serif text-xl font-light mb-1 ${m.featured ? 'text-[#b5936b]' : 'text-[#1a1a1a]'}`}>{m.pays}</p>
            <p class={`hp-sans text-xs uppercase tracking-wider ${m.featured ? 'text-[#b5936b]/60' : 'text-[#1a1a1a]/35'}`}>{m.label}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div style="background:#1a1a1a" class="py-5 overflow-hidden select-none">
    <div class="ticker-inner hp-sans text-white/25 text-xs uppercase tracking-[0.3em]">
      {['French','Polish','English','German','Spanish','Italian','French','Polish','English','German','Spanish','Italian'].map(l => (
        <span class="px-8">{l}&nbsp;&nbsp;·</span>
      ))}
    </div>
  </div>

  <section class="bg-white py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-14 text-center reveal" style="color:rgba(26,26,26,0.35)">Our services</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px stagger" style="background:rgba(26,26,26,0.06)">
        {services.map(s => (
          <a href={s.href} class="group bg-white p-8 flex flex-col gap-4 hover:bg-[#f7f5f2] transition-colors">
            <span class="text-3xl">{s.icon}</span>
            <p class="hp-serif text-xl group-hover:text-[#b5936b] transition-colors" style="color:#1a1a1a">{s.titre}</p>
            <p class="hp-sans text-sm leading-relaxed flex-1" style="color:rgba(26,26,26,0.5)">{s.desc}</p>
            <span class="hp-sans text-xs mt-2" style="color:#b5936b">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="background:#1a1a1a" class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 stagger">
        {stats.map(s => (
          <div class="text-center">
            <p class="hp-serif text-4xl md:text-5xl font-light mb-2" style="color:#b5936b">{s.num}{s.unit}</p>
            <p class="hp-sans text-xs leading-snug" style="color:rgba(255,255,255,0.4)">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:#1a1a1a" class="py-40 px-6 text-center">
    <div class="max-w-2xl mx-auto reveal">
      <h2 class="hp-serif text-5xl md:text-6xl font-light text-white leading-[1.1] mb-6">
        An international project?<br/><em class="italic" style="color:#b5936b">Let's talk.</em>
      </h2>
      <p class="hp-sans text-base mb-14 max-w-md mx-auto leading-[1.8]" style="color:rgba(255,255,255,0.4)">
        Describe your mission. We'll respond within 24h with a tailored proposal.
      </p>
      <a href="/en/contact" class="hp-sans inline-block px-12 py-6 text-xs uppercase tracking-widest hover:opacity-90 transition-opacity" style="background:#b5936b;color:#1a1a1a">
        Contact us →
      </a>
    </div>
  </section>

  <script>
    const io = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target);} }), {threshold:0.1});
    document.querySelectorAll('.reveal,.stagger').forEach(el => io.observe(el));
  </script>
</Layout>
