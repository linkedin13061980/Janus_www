---
import Layout from '../../../layouts/Layout.astro';
const locale = 'fr';
const currentPath = '/marches/italie';
---
<Layout
  title="S'implanter en Italie | JANUS Agence Linguistique Lyon"
  description="Italie, 3e économie européenne, 3e partenaire commercial de la France. JANUS vous accompagne sur le marché franco-italien — luxe, agroalimentaire, industrie."
  locale={locale}
  currentPath={currentPath}
>

  <!-- Hero -->
  <section class="bg-anthracite pt-36 pb-24 px-6 relative overflow-hidden">
    <div class="absolute top-16 right-8 text-[10rem] opacity-[0.06] pointer-events-none select-none leading-none">🇮🇹</div>
    <div class="max-w-3xl mx-auto relative">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Marché italien · Franco-italien</p>
      <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-[1.1] mb-8">
        S'implanter en<br/><em class="italic text-gold">Italie.</em>
      </h1>
      <p class="text-white/50 text-lg max-w-lg leading-relaxed">
        3e économie de l'UE et 3e partenaire commercial de la France. Les liens franco-italiens sont profonds — industriels, culturels, commerciaux. Mais la langue reste un vrai levier compétitif.
      </p>
    </div>
  </section>

  <!-- Chiffres clés -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-anthracite/10">
        {[
          { num: '2 000 Mds €', label: 'PIB — 3e économie de l\'UE', source: '2023' },
          { num: '60 Mds €', label: 'Échanges franco-italiens', source: '3e partenaire · 2023' },
          { num: '1 200+', label: 'Entreprises françaises en Italie', source: 'Direction du Trésor' },
        ].map(c => (
          <div class="py-8 px-6 first:pl-0 last:pr-0">
            <p class="text-4xl font-serif font-bold text-gold mb-2">{c.num}</p>
            <p class="text-anthracite/70 text-sm leading-tight mb-1">{c.label}</p>
            <p class="text-anthracite/30 text-xs">{c.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pourquoi l'Italie -->
  <section class="bg-[#f5f5f3] py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-anthracite/40 text-xs uppercase tracking-[0.3em] mb-12">Pourquoi l'Italie</p>
      <div class="divide-y divide-anthracite/10">
        {[
          { n: '01', titre: 'Secteurs d\'excellence mondiale', desc: 'Luxe, mode, agroalimentaire, design, automobile, mécanique de précision — l\'Italie est leader mondial dans des secteurs où la France est aussi très présente. Les synergies sont évidentes.' },
          { n: '02', titre: 'Un marché de proximité sous-exploité', desc: 'Malgré la proximité géographique et culturelle, beaucoup d\'entreprises françaises n\'ont pas encore structuré leur présence italienne. Un avantage compétitif pour celles qui bougent maintenant.' },
          { n: '03', titre: 'La relation commerciale se noue en italien', desc: 'Les Italiens apprécient particulièrement qu\'on leur parle dans leur langue. Dans les secteurs du luxe, de l\'artisanat et de l\'industrie régionale, l\'italien n\'est pas une option — c\'est une marque de respect.' },
        ].map(r => (
          <div class="py-10 flex gap-8">
            <span class="text-gold/25 font-serif text-sm w-6 shrink-0 pt-1">{r.n}</span>
            <div>
              <p class="text-anthracite font-serif text-xl mb-3">{r.titre}</p>
              <p class="text-anthracite/55 text-sm leading-relaxed max-w-lg">{r.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Rôle JANUS -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-anthracite/40 text-xs uppercase tracking-[0.3em] mb-6">Le rôle de JANUS</p>
      <h2 class="text-4xl font-serif font-light text-anthracite mb-4 leading-tight">
        Votre partenaire<br/>pour le marché franco-italien.
      </h2>
      <p class="text-anthracite/55 text-lg leading-relaxed mb-16 max-w-xl">
        Formateurs et traducteurs natifs italiens. Expertise sectorielle luxe, agroalimentaire, industrie et droit des affaires franco-italien.
      </p>
      <div class="divide-y divide-anthracite/10">
        {[
          { titre: 'Italien des affaires sur mesure', desc: 'Formation centrée sur vos secteurs cibles : luxe, mode, agroalimentaire, industrie, juridique. Tous niveaux, Qualiopi, éligible OPCO.' },
          { titre: 'Interprétariat IT ↔ FR', desc: 'Négociations, salons professionnels, réunions stratégiques. Interprètes natifs avec expérience sectorielle.' },
          { titre: 'Traduction IT ↔ FR', desc: 'Contrats commerciaux, fiches produits, documentation technique, brochures. Adaptation stylistique aux codes du marché cible.' },
          { titre: 'Conseil interculturel franco-italien', desc: 'Les codes de conduite italiens varient selon les régions et les secteurs. Nos experts vous préparent aux spécificités locales.' },
        ].map(s => (
          <div class="py-8">
            <p class="text-anthracite font-medium text-base mb-2">{s.titre}</p>
            <p class="text-anthracite/50 text-sm leading-relaxed max-w-lg">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-anthracite py-40 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        Un projet en Italie ?<br/><em class="italic text-gold">Parlons-en.</em>
      </h2>
      <p class="text-white/40 text-base mb-12">Premier échange gratuit et confidentiel.</p>
      <a href="/fr/contact?marche=italie" class="inline-block px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">
        Discuter de mon projet
      </a>
    </div>
  </section>

</Layout>
