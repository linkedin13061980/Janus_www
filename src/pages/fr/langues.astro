---
import Layout from '../../layouts/Layout.astro';
const locale = 'fr';
const currentPath = '/langues';

const langues = [
  {
    flag: '🇬🇧',
    nom: 'Anglais',
    label: 'Langue des affaires',
    desc: 'Formateurs britanniques et américains. Business English, TOEIC/TOEFL, anglais technique.',
    tags: ['Business English', 'Coaching cadres', 'TOEIC / TOEFL', 'Industrie · Santé · Finance'],
    featured: false,
  },
  {
    flag: '🇵🇱',
    nom: 'Polonais',
    label: 'Spécialité exclusive Lyon',
    desc: 'Seule agence lyonnaise spécialisée FR↔PL. Formation, interprétariat, réseau CCIFP actif.',
    tags: ['Formation pro', 'Interprétariat', 'Réseau CCIFP', 'Accompagnement terrain'],
    featured: true,
  },
  {
    flag: '🇫🇷',
    nom: 'Français FLE',
    label: 'Pour salariés étrangers',
    desc: 'Obligation légale 2024 pour les allophones. Financement CPF sans reste à charge. Attestation Qualiopi.',
    tags: ['FLE pro', 'CPF sans reste à charge', 'Qualiopi', 'Allophones'],
    featured: false,
  },
  {
    flag: '🇩🇪',
    nom: 'Allemand',
    label: 'Zone DACH',
    desc: 'Marchés allemand, autrichien, suisse. Formateurs natifs spécialisés industrie et commerce.',
    tags: ['Allemand des affaires', 'Industrie', 'Zone DACH', 'Formateurs natifs'],
    featured: false,
  },
  {
    flag: '🇪🇸',
    nom: 'Espagnol',
    label: 'Hispanophone',
    desc: 'Espagne et Amérique latine. Espagnol des affaires, interprétariat disponible.',
    tags: ['Espagnol pro', 'Amérique latine', 'Interprétariat', 'Commerce international'],
    featured: false,
  },
  {
    flag: '🇮🇹',
    nom: 'Italien',
    label: 'Franco-italien',
    desc: 'Relations commerciales franco-italiennes. Formateurs spécialisés luxe et industrie.',
    tags: ['Italien des affaires', 'Luxe', 'Industrie', 'Traduction disponible'],
    featured: false,
  },
];
---

<Layout
  title="Nos Langues | JANUS Agence Linguistique Lyon"
  description="Anglais, polonais, français FLE, allemand, espagnol, italien — formation, interprétariat et traduction par des natifs à Lyon."
  locale={locale}
  currentPath={currentPath}
>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />
  <style is:global>
    .hp-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
    .hp-sans  { font-family: 'DM Sans', system-ui, sans-serif; }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .stagger > * { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
    .stagger.in > *:nth-child(1) { opacity:1; transform:none; transition-delay:.05s }
    .stagger.in > *:nth-child(2) { opacity:1; transform:none; transition-delay:.15s }
    .stagger.in > *:nth-child(3) { opacity:1; transform:none; transition-delay:.25s }
    .stagger.in > *:nth-child(4) { opacity:1; transform:none; transition-delay:.35s }
    .stagger.in > *:nth-child(5) { opacity:1; transform:none; transition-delay:.45s }
    .stagger.in > *:nth-child(6) { opacity:1; transform:none; transition-delay:.55s }
  </style>

  <!-- HERO -->
  <section style="background:#f7f5f2" class="pt-36 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8 reveal" style="color:#b5936b">Nos langues</p>
      <h1 class="hp-serif text-5xl md:text-6xl font-light leading-[1.1] mb-6 reveal" style="color:#1a1a1a">
        Six langues.<br/><em class="italic" style="color:#b5936b">100% natifs.</em>
      </h1>
      <p class="hp-sans text-lg max-w-lg leading-[1.8] reveal" style="color:rgba(26,26,26,0.5)">
        Chaque langue est portée par des formateurs et interprètes natifs, sélectionnés pour leur expertise métier.
      </p>
    </div>
  </section>

  <!-- GRILLE LANGUES -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px stagger" style="background:rgba(26,26,26,0.06)">
        {langues.map(l => (
          <div class={`p-10 flex flex-col gap-4 ${l.featured ? '' : 'bg-white'}`} style={l.featured ? 'background:#1a1a1a' : ''}>
            <span class="text-4xl">{l.flag}</span>
            <div>
              <p class="hp-sans text-[9px] uppercase tracking-[0.25em] mb-2" style={`color:${l.featured ? 'rgba(181,147,107,0.7)' : 'rgba(181,147,107,0.8)'}`}>{l.label}</p>
              <p class="hp-serif text-2xl font-light mb-3" style={`color:${l.featured ? '#b5936b' : '#1a1a1a'}`}>{l.nom}</p>
              <p class="hp-sans text-sm leading-[1.7]" style={`color:${l.featured ? 'rgba(255,255,255,0.5)' : 'rgba(26,26,26,0.5)'}`}>{l.desc}</p>
            </div>
            <div class="flex flex-wrap gap-2 mt-auto pt-4">
              {l.tags.map(tag => (
                <span class="hp-sans text-[10px] border px-3 py-1 rounded-full" style="color:rgba(181,147,107,0.8);border-color:rgba(181,147,107,0.25)">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#1a1a1a" class="py-32 px-6 text-center">
    <div class="max-w-xl mx-auto reveal">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8" style="color:rgba(255,255,255,0.3)">Devis gratuit sous 24h</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light text-white mb-6 leading-tight">
        Quelle langue pour<br/><em class="italic" style="color:#b5936b">votre projet ?</em>
      </h2>
      <a href="/fr/contact" class="hp-sans inline-block px-10 py-5 text-xs uppercase tracking-widest hover:opacity-80 transition-opacity" style="background:#b5936b;color:#1a1a1a">
        Nous contacter →
      </a>
    </div>
  </section>

  <script>
    const io = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target);} }), {threshold:0.1});
    document.querySelectorAll('.reveal,.stagger').forEach(el => io.observe(el));
  </script>
</Layout>
