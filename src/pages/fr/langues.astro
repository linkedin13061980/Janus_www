---
import Layout from '../../layouts/Layout.astro';
const locale = 'fr';
const currentPath = '/langues';
---
<Layout
  title="Nos Langues | JANUS Agence Linguistique Lyon"
  description="Anglais, polonais, français FLE, allemand, espagnol, italien — formation, interprétariat et traduction par des natifs à Lyon."
  locale={locale}
  currentPath={currentPath}
>

  <!-- Hero -->
  <section class="bg-anthracite pt-36 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Nos langues</p>
      <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-[1.1] mb-8">
        Six langues.<br/><em class="italic text-gold">100% natifs.</em>
      </h1>
      <p class="text-white/50 text-lg max-w-lg leading-relaxed">
        Chaque langue est portée par des formateurs et interprètes natifs, sélectionnés pour leur expertise métier.
      </p>
    </div>
  </section>

  <!-- Anglais -->
  <section class="py-24 px-6 border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-3xl mb-6">🇬🇧</p>
      <p class="text-gold/50 text-xs uppercase tracking-widest mb-2">Langue des affaires</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">Anglais professionnel</h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Notre cœur de métier depuis 2016. Formateurs britanniques et américains. De A1 au TOEIC, centré sur votre secteur et vos objectifs réels.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Business English — réunions, négociations, emails, présentations',
          'Coaching individuel cadres et managers',
          'Préparation TOEIC / TOEFL / IELTS',
          'Anglais technique : industrie, santé, finance, juridique',
          'Interprétariat EN ↔ FR · Traduction documents',
          'Financement CPF jusqu\'à 1 500 € · OPCO · PDC',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-gold shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-gold/40 text-gold uppercase tracking-wider hover:bg-gold hover:text-anthracite transition-colors text-sm">Demander un devis anglais</a>
    </div>
  </section>

  <!-- Polonais -->
  <section class="py-24 px-6 bg-anthracite-light border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-3xl mb-6">🇵🇱</p>
      <p class="text-gold text-xs uppercase tracking-widest mb-2">Spécialité exclusive à Lyon</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">Polonais professionnel</h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Seule agence spécialisée polonais à Lyon. Réseau CCIFP actif. Accompagnement physique en Pologne disponible.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Polonais des affaires — communication, déplacements en Pologne',
          'Interprétariat PL ↔ FR en France et sur site en Pologne',
          'Accompagnement terrain : Varsovie, Cracovie, Wrocław, Katowice…',
          'Accueil de délégations polonaises à Lyon',
          'Traduction contrats, appels d\'offre, correspondances',
          'Conseil interculturel franco-polonais',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-gold shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <div class="flex gap-4">
        <a href="/fr/contact" class="inline-block px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">Contacter notre équipe</a>
        <a href="/fr/pologne-investir" class="inline-block px-8 py-4 border border-white/15 text-white/50 uppercase tracking-wider hover:border-gold hover:text-gold transition-colors text-sm">Investir en Pologne</a>
      </div>
    </div>
  </section>

  <!-- FLE -->
  <section class="py-24 px-6 border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-3xl mb-6">🇫🇷</p>
      <p class="text-gold/50 text-xs uppercase tracking-widest mb-2">Intégration professionnelle</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">Français Langue Étrangère</h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Pour vos salariés non francophones. Financement CPF sans reste à charge pour les bénéficiaires du CIR. TCF et DELF inclus.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Français professionnel adapté à votre secteur',
          'Préparation TCF / DELF / DALF',
          'CPF sans reste à charge pour bénéficiaires CIR',
          'Présentiel Lyon ou visioconférence',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-gold shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-gold/40 text-gold uppercase tracking-wider hover:bg-gold hover:text-anthracite transition-colors text-sm">Renseignements FLE</a>
    </div>
  </section>

  <!-- Autres langues -->
  <section class="py-24 px-6 bg-anthracite-light border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Aussi disponibles</p>
      <h2 class="text-4xl font-serif font-light text-white mb-16 leading-tight">
        Allemand, espagnol,<br/>italien.
      </h2>
      <div class="divide-y divide-white/10">
        {[
          { flag: '🇩🇪', lang: 'Allemand', detail: 'Formation B2B · Interprétariat · Traduction · Secteurs industrie et automobile' },
          { flag: '🇪🇸', lang: 'Espagnol', detail: 'Formation professionnelle · Marchés LATAM et Espagne · Interprétariat' },
          { flag: '🇮🇹', lang: 'Italien', detail: 'Formation et traduction · Secteurs mode, luxe, industrie, juridique' },
        ].map(l => (
          <div class="py-8 flex items-start gap-6">
            <span class="text-3xl shrink-0">{l.flag}</span>
            <div>
              <p class="text-white font-medium text-lg mb-1">{l.lang}</p>
              <p class="text-white/40 text-sm">{l.detail}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12">
        <a href="/fr/contact" class="inline-block px-8 py-4 border border-gold/40 text-gold uppercase tracking-wider hover:bg-gold hover:text-anthracite transition-colors text-sm">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- CTA financement -->
  <section class="py-40 px-6 bg-anthracite border-t border-gold/10 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        Votre formation peut être<br/><em class="italic text-gold">financée à 100%.</em>
      </h2>
      <p class="text-white/40 text-base mb-12">CPF, OPCO, PDC — JANUS gère le dossier pour vous.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fr/contact" class="px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">Vérifier mon financement</a>
        <a href="/fr/financement" class="px-10 py-5 border border-white/15 text-white/60 uppercase tracking-wider hover:border-gold hover:text-gold transition-colors text-sm">En savoir plus</a>
      </div>
    </div>
  </section>

</Layout>
