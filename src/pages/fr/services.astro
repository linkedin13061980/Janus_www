---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/layout/PageHero.astro';
import ServiceCard from '../../components/ui/ServiceCard.astro';
import { localePath } from '../../i18n/utils';
import content from '../../content/fr/services.json';

const locale = 'fr';
const currentPath = '/services';
---

<Layout
  title={content.meta.title}
  description={content.meta.description}
  locale={locale}
  currentPath={currentPath}
>
  <PageHero
    label={content.hero.label}
    title={content.hero.title}
    subtitle={content.hero.subtitle}
  />

  {content.services
    .sort((a, b) => a.order - b.order)
    .map((service, index) => (
      <ServiceCard
        locale={locale}
        order={service.order}
        titre={service.titre}
        desc={service.desc}
        items={service.items}
        cta={service.cta}
        href={service.href}
        badge={service.badge}
        alternate={index % 2 !== 0}
      />
    ))
  }

  <section class="py-40 px-6 bg-anthracite border-t border-gold/10 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        {content.cta.title}
      </h2>
      <p class="text-white/40 text-base mb-12">{content.cta.subtitle}</p>
      <a
        href={localePath(locale, content.cta.href)}
        class="inline-block px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm"
      >
        {content.cta.btn}
      </a>
    </div>
  </section>
</Layout>
