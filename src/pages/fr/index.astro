---
import Layout from '../../layouts/Layout.astro';

const locale = 'fr';
const currentPath = '/';
// v2.1

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JANUS Agence Linguistique",
  "description": "Agence linguistique B2B multi-langues à Lyon. Formation, interprétariat, accompagnement terrain, traduction.",
  "url": "https://agence-janus.fr",
  "telephone": "+33967056831",
  "email": "contact@agence-janus.fr",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lyon",
    "postalCode": "69003",
    "addressCountry": "FR"
  },
  "areaServed": ["France", "Pologne", "Royaume-Uni", "Allemagne", "Espagne", "Italie"],
  "hasCredential": "Qualiopi",
  "foundingDate": "2021",
  "sameAs": ["https://www.linkedin.com/company/janus-agence-linguistique"]
};

const marches = [
  {
    flag: '🇵🇱',
    pays: 'Pologne',
    label: 'Prioritaire',
    href: '/fr/pologne-investir',
    featured: true,
  },
  {
    flag: '🇬🇧',
    pays: 'Royaume-Uni',
    label: 'Business',
    href: '/fr/marches/royaume-uni',
    featured: false,
  },
  {
    flag: '🇩🇪',
    pays: 'Allemagne',
    label: 'Zone DACH',
    href: '/fr/marches/allemagne',
    featured: false,
  },
  {
    flag: '🇪🇸',
    pays: 'Espagne',
    label: 'Hispanophone',
    href: '/fr/marches/espagne',
    featured: false,
  },
  {
    flag: '🇮🇹',
    pays: 'Italie',
    label: 'Franco-italien',
    href: '/fr/marches/italie',
    featured: false,
  },
  {
    flag: '🇫🇷',
    pays: 'France',
    label: 'FLE · Allophones',
    href: '/fr/langues#fle',
    featured: false,
  },
];
---

<Layout
  title="JANUS Agence Linguistique | Formation, Interprétariat, Traduction | Lyon"
  description="Un seul partenaire. Plusieurs services. Pour lancer ou développer votre business à l'étranger — formation, interprétariat, accompagnement terrain, traduction."
  locale={locale}
  currentPath={currentPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <!-- Hero + Sélecteur pays -->
  <section class="bg-anthracite pt-36 pb-24 px-6">
    <div class="max-w-4xl mx-auto">

      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Lyon · Depuis 2021 · Qualiopi</p>

      <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-[1.1] mb-4">
        Où souhaitez-vous<br/><em class="italic text-gold">vous développer ?</em>
      </h1>
      <p class="text-white/45 text-lg mb-16 max-w-lg leading-relaxed">
        Choisissez votre marché cible.
      </p>

      <!-- Tuiles pays -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
        {marches.map(m => (
          <a
            href={m.href}
            class={`group block p-6 md:p-8 border transition-all duration-200 ${
              m.featured
                ? 'border-gold bg-anthracite-light hover:border-gold hover:bg-gold/10'
                : 'border-white/10 bg-white/[0.02] hover:border-gold/60 hover:bg-white/[0.05]'
            }`}
          >
            <p class="text-4xl mb-4 leading-none">{m.flag}</p>
            <p class={`font-serif text-lg font-light mb-1 ${m.featured ? 'text-gold' : 'text-white group-hover:text-gold transition-colors'}`}>
              {m.pays}
            </p>
            <p class={`text-xs uppercase tracking-wider ${m.featured ? 'text-gold/60' : 'text-white/35'}`}>
              {m.label}
            </p>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- Baseline -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-anthracite/40 text-xs uppercase tracking-[0.3em] mb-6">Notre promesse</p>
      <h2 class="text-3xl md:text-4xl font-serif font-light text-anthracite leading-snug">
        Un seul partenaire. Plusieurs services.<br/>Pour lancer ou développer votre business à l'étranger.
      </h2>
    </div>
  </section>

  <!-- 4 Services -->
  <section class="bg-[#f5f5f3] py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-anthracite/40 text-xs uppercase tracking-[0.3em] mb-16 text-center">Ce que nous faisons</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-anthracite/10">
        {[
          {
            icon: '🎓',
            titre: 'Formation linguistique',
            desc: 'Sur mesure, Qualiopi, finançable CPF/OPCO.',
            href: '/fr/services',
          },
          {
            icon: '🎙️',
            titre: 'Interprétariat',
            desc: 'Natifs, NDA systématique, déplacement inclus.',
            href: '/fr/services',
          },
          {
            icon: '🤝',
            titre: 'Accompagnement terrain',
            desc: 'Présence physique sur site en France et en Pologne.',
            href: '/fr/services',
          },
          {
            icon: '📄',
            titre: 'Traduction',
            desc: 'Juridique, technique, commercial. Natifs spécialisés.',
            href: '/fr/services',
          },
        ].map(s => (
          <a href={s.href} class="group bg-white p-8 md:p-10 flex flex-col gap-4 hover:bg-anthracite transition-colors duration-200">
            <span class="text-3xl">{s.icon}</span>
            <div>
              <p class="text-anthracite font-serif text-xl mb-2 group-hover:text-gold transition-colors">{s.titre}</p>
              <p class="text-anthracite/55 text-sm leading-relaxed group-hover:text-white/50 transition-colors">{s.desc}</p>
            </div>
            <span class="text-anthracite/25 text-sm group-hover:text-gold transition-colors mt-auto">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pourquoi JANUS -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-anthracite/40 text-xs uppercase tracking-[0.3em] mb-16 text-center">Pourquoi JANUS</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 text-center">
        {[
          {
            num: '01',
            titre: 'Un seul interlocuteur',
            desc: 'Formation, interprétariat, terrain, traduction — une seule agence pour toute votre mission.',
          },
          {
            num: '02',
            titre: 'Présence physique',
            desc: 'Nos experts se déplacent sur site en France et en Pologne.',
          },
          {
            num: '03',
            titre: 'NDA systématique',
            desc: 'Confidentialité formalisée avant chaque mission, sans exception.',
          },
        ].map(r => (
          <div>
            <p class="text-gold/30 font-serif text-4xl font-bold mb-4">{r.num}</p>
            <p class="text-anthracite font-serif text-lg mb-3">{r.titre}</p>
            <p class="text-anthracite/50 text-sm leading-relaxed">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="bg-[#f5f5f3] py-12 px-6 border-y border-anthracite/8">
    <div class="max-w-3xl mx-auto flex flex-wrap items-center justify-center gap-8 text-center">
      <div>
        <p class="text-2xl font-serif font-bold text-anthracite">Qualiopi</p>
        <p class="text-anthracite/40 text-xs uppercase tracking-wider mt-1">Certifiée · N° 84692002569</p>
      </div>
      <div class="w-px h-8 bg-anthracite/15 hidden sm:block"></div>
      <div>
        <p class="text-2xl font-serif font-bold text-anthracite">CPF · OPCO · PDC</p>
        <p class="text-anthracite/40 text-xs uppercase tracking-wider mt-1">Financement formations</p>
      </div>
      <div class="w-px h-8 bg-anthracite/15 hidden sm:block"></div>
      <div>
        <p class="text-2xl font-serif font-bold text-anthracite">6 langues</p>
        <p class="text-anthracite/40 text-xs uppercase tracking-wider mt-1">100% natifs</p>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-anthracite py-40 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-serif font-light text-white mb-6 leading-tight">
        Parlons de<br/><em class="italic text-gold">votre projet.</em>
      </h2>
      <p class="text-white/40 text-base mb-12">Réponse sous 24h. Premier échange gratuit et confidentiel.</p>
      <a href="/fr/contact" class="inline-block px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">
        Nous contacter
      </a>
    </div>
  </section>

</Layout>
