---
import Layout from '../../layouts/Layout.astro';

const locale = 'fr';
const currentPath = '/';

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JANUS Agence Linguistique",
  "description": "Agence linguistique B2B spécialisée franco-polonais à Lyon. Formation, interprétariat, accompagnement terrain, traduction.",
  "url": "https://agence-janus.fr",
  "telephone": "+33967056831",
  "email": "contact@agence-janus.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "20 ter rue Julien",
    "addressLocality": "Lyon",
    "postalCode": "69003",
    "addressCountry": "FR"
  },
  "areaServed": ["France", "Pologne", "Royaume-Uni"],
  "hasCredential": "Qualiopi",
  "foundingDate": "2021",
  "sameAs": ["https://www.linkedin.com/company/janus-agence-linguistique"]
};
---

<Layout
  title="JANUS Agence Linguistique | Traduction, Formation, Interprétariat | Lyon"
  description="Agence linguistique B2B à Lyon spécialisée franco-polonais. Formation professionnelle Qualiopi, interprétariat, accompagnement terrain et traduction."
  locale={locale}
  currentPath={currentPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-anthracite via-anthracite-light to-anthracite opacity-90"></div>
    <div class="absolute inset-0 bg-[url('/hero-bg.jpg')] bg-cover bg-center opacity-10"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold text-sm uppercase tracking-[0.3em] mb-6 font-medium">Agence Linguistique B2B</p>
      <h1 class="text-5xl md:text-7xl font-serif font-bold text-white mb-6 leading-tight">
        Votre passerelle<br/>
        <span class="text-gold">franco-polonaise</span>
      </h1>
      <p class="text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        Formation professionnelle, interprétariat, accompagnement terrain et traduction pour les entreprises qui franchissent les frontières.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fr/contact" class="px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors">
          Nous contacter
        </a>
        <a href="/fr/services" class="px-8 py-4 border border-gold/50 text-white uppercase tracking-wider hover:border-gold hover:text-gold transition-colors">
          Nos services
        </a>
      </div>
    </div>
  </section>

  <!-- Badges de confiance -->
  <section class="py-12 border-y border-gold/10">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-serif font-bold text-gold">2021</p>
          <p class="text-white/50 text-sm mt-1 uppercase tracking-wider">Fondée</p>
        </div>
        <div>
          <p class="text-3xl font-serif font-bold text-gold">3</p>
          <p class="text-white/50 text-sm mt-1 uppercase tracking-wider">Langues</p>
        </div>
        <div>
          <p class="text-3xl font-serif font-bold text-gold">Qualiopi</p>
          <p class="text-white/50 text-sm mt-1 uppercase tracking-wider">Certifiée</p>
        </div>
        <div>
          <p class="text-3xl font-serif font-bold text-gold">NDA</p>
          <p class="text-white/50 text-sm mt-1 uppercase tracking-wider">Confidentialité</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 max-w-6xl mx-auto px-4">
    <div class="text-center mb-14">
      <p class="text-gold text-sm uppercase tracking-widest mb-3">Ce que nous faisons</p>
      <h2 class="text-4xl font-serif font-bold text-white">Nos expertises</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {[
        {
          icon: '🎓',
          title: 'Formation professionnelle',
          desc: 'Anglais, polonais, français FLE — programmes sur mesure certifiés Qualiopi, éligibles CPF et OPCO.',
          href: '/fr/services'
        },
        {
          icon: '🎙️',
          title: 'Interprétariat',
          desc: 'Consécutif et simultané pour vos négociations, assemblées générales et déplacements en Pologne. NDA systématique.',
          href: '/fr/services'
        },
        {
          icon: '🤝',
          title: 'Accompagnement terrain',
          desc: 'Présence physique sur site en France ou en Pologne pour faciliter vos opérations B2B. NDA systématique.',
          href: '/fr/services'
        },
        {
          icon: '📄',
          title: 'Traduction',
          desc: 'Documents juridiques, techniques et commerciaux. Précision terminologique et respect des délais.',
          href: '/fr/services'
        }
      ].map((s) => (
        <a href={s.href} class="group p-8 border border-gold/20 hover:border-gold/60 bg-anthracite-light transition-all">
          <span class="text-3xl">{s.icon}</span>
          <h3 class="text-xl font-serif font-bold text-white mt-4 mb-3 group-hover:text-gold transition-colors">{s.title}</h3>
          <p class="text-white/60 leading-relaxed">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA Pologne -->
  <section class="py-20 bg-anthracite-light border-y border-gold/10">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-gold text-sm uppercase tracking-widest mb-4">Opportunité</p>
      <h2 class="text-4xl font-serif font-bold text-white mb-6">Investir en Pologne ?</h2>
      <p class="text-white/60 text-lg mb-8 leading-relaxed">
        La Pologne est la 6e économie européenne. JANUS vous accompagne dans vos projets d'implantation, de recrutement et de développement commercial.
      </p>
      <a href="/fr/pologne-investir" class="inline-block px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors">
        En savoir plus
      </a>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20 max-w-2xl mx-auto px-4 text-center">
    <h2 class="text-4xl font-serif font-bold text-white mb-6">Parlons de votre projet</h2>
    <p class="text-white/60 text-lg mb-8">
      Chaque mission est unique. Contactez-nous pour un devis personnalisé sous 24h.
    </p>
    <a href="/fr/contact" class="inline-block px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors">
      Prendre contact
    </a>
  </section>
</Layout>
