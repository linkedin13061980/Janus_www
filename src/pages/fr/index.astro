---
import Layout from '../../layouts/Layout.astro';

const locale = 'fr';
const currentPath = '/';

const marches = [
  { flag: '🇵🇱', pays: 'Pologne',       label: 'Prioritaire',      href: '/fr/marches/pologne',     featured: true  },
  { flag: '🇬🇧', pays: 'Royaume-Uni',   label: 'Business',         href: '/fr/marches/royaume-uni', featured: false },
  { flag: '🇩🇪', pays: 'Allemagne',     label: 'Zone DACH',        href: '/fr/marches/allemagne',   featured: false },
  { flag: '🇪🇸', pays: 'Espagne',       label: 'Hispanophone',     href: '/fr/marches/espagne',     featured: false },
  { flag: '🇮🇹', pays: 'Italie',        label: 'Franco-italien',   href: '/fr/marches/italie',      featured: false },
  { flag: '🇫🇷', pays: 'France',        label: 'FLE · Allophones', href: '/fr/langues#fle',         featured: false },
];

const services = [
  { label: 'Formation',        href: '/fr/services/formation'       },
  { label: 'Interprétariat',   href: '/fr/services/interpretariat'  },
  { label: 'Accompagnement',   href: '/fr/services/terrain'         },
  { label: 'Traduction',       href: '/fr/services/traduction'      },
  { label: 'Chef de projet',   href: '/fr/services/chef-de-projet'  },
];

const situations = [
  {
    n: '01',
    titre: 'Vos partenaires ou fournisseurs sont étrangers — et les échanges coûtent du temps et de l\'argent',
    solution: 'JANUS prend en charge la communication de bout en bout : interprétariat, préparation culturelle, accompagnement sur site.',
  },
  {
    n: '02',
    titre: 'Vos équipes doivent travailler en langue étrangère mais ne sont pas prêtes',
    solution: 'Programmes de formation sur mesure, finançables OPCO/CPF. Certifié Qualiopi.',
  },
  {
    n: '03',
    titre: 'Vous négociez un contrat ou une acquisition à l\'international',
    solution: 'Interprètes natifs spécialisés, NDA signé avant chaque mission. Présence physique possible en France et en Europe.',
  },
];
---

<Layout
  title="JANUS — Agence linguistique B2B | Lyon · Pologne · International"
  description="JANUS accompagne les PME et ETI lyonnaises dans leurs échanges avec la Pologne et les marchés internationaux. Formation, interprétariat, terrain, traduction."
  locale={locale}
  currentPath={currentPath}
>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />
  <style is:global>
    .hp-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
    .hp-sans  { font-family: 'DM Sans', system-ui, sans-serif; }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .stagger > * { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
    .stagger.in > *:nth-child(1) { opacity:1; transform:none; transition-delay:.05s }
    .stagger.in > *:nth-child(2) { opacity:1; transform:none; transition-delay:.12s }
    .stagger.in > *:nth-child(3) { opacity:1; transform:none; transition-delay:.19s }
    .stagger.in > *:nth-child(4) { opacity:1; transform:none; transition-delay:.26s }
    .stagger.in > *:nth-child(5) { opacity:1; transform:none; transition-delay:.33s }
    .stagger.in > *:nth-child(6) { opacity:1; transform:none; transition-delay:.40s }
    .flag-tile { text-decoration: none !important; transition: transform .2s ease, box-shadow .2s ease; }
    .flag-tile:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.10); }
    .flag-tile .flag { transition: transform .4s cubic-bezier(.34,1.56,.64,1); display: inline-block; }
    .flag-tile:hover .flag { transform: scale(1.3) rotate(-5deg); }
    .sit-tile { cursor: pointer; transition: background .25s ease, border-color .25s ease; text-decoration: none !important; }
    .sit-tile * { text-decoration: none !important; }
  </style>

  <!-- ① HERO -->
  <section style="background:#f7f5f2" class="pt-36 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.45em] mb-10 reveal" style="color:#b5936b">
        Lyon · Spécialiste franco-polonais · Qualiopi
      </p>
      <h1 class="hp-serif font-light leading-[1.05] mb-8 reveal" style="font-size:clamp(2.5rem,6vw,4.5rem);color:#1a1a1a">
        Vous développez votre activité<br/>à l'international ?
      </h1>
      <p class="hp-sans text-lg max-w-xl leading-[1.8] mb-12 reveal" style="color:rgba(26,26,26,0.5)">
        JANUS accompagne les PME et ETI de la région lyonnaise dans leurs échanges avec la Pologne et les marchés internationaux.
      </p>
      <p class="hp-sans text-xs uppercase tracking-[0.3em] mb-8 reveal" style="color:rgba(26,26,26,0.35)">
        Choisissez votre marché cible
      </p>

      <!-- DRAPEAUX -->
      <div class="grid grid-cols-3 md:grid-cols-6 gap-3 stagger">
        {marches.map(m => (
          <a href={m.href} class={`flag-tile block p-5 md:p-6 border text-center ${m.featured ? 'bg-[#1a1a1a] border-[#b5936b]' : 'bg-white border-[#1a1a1a]/10 hover:border-[#b5936b]/50'}`}>
            <span class="flag text-3xl md:text-4xl block mb-3 leading-none">{m.flag}</span>
            <p class={`hp-serif text-sm font-light ${m.featured ? 'text-[#b5936b]' : 'text-[#1a1a1a]'}`}>{m.pays}</p>
            <p class="hp-sans text-[9px] uppercase tracking-wider mt-1" style={m.featured ? 'color:rgba(181,147,107,0.6)' : 'color:rgba(26,26,26,0.3)'}>{m.label}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ② SITUATIONS -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-6 reveal" style="color:rgba(26,26,26,0.35)">Vous êtes dans cette situation ?</p>
      <div class="flex flex-col gap-[2px]">
        {situations.map((s, i) => (
          <div class="sit-tile bg-[#f7f5f2] border border-[#1a1a1a]/6 p-8 md:p-10" data-index={i}>
            <div class="flex items-start gap-6 md:gap-10">
              <p class="hp-serif font-light flex-shrink-0 leading-none" style="font-size:3rem;color:rgba(181,147,107,0.15)">{s.n}</p>
              <div class="flex-1">
                <p class="hp-serif text-lg md:text-xl font-light sit-title mb-0" style="color:#1a1a1a">{s.titre}</p>
                <div class="sit-detail mt-4" style="display:none">
                  <p class="hp-sans text-sm leading-[1.8]" style="color:rgba(26,26,26,0.55)">{s.solution}</p>
                  <a href="/fr/contact" class="hp-sans text-xs mt-4 inline-block" style="color:#b5936b">Nous contacter →</a>
                </div>
              </div>
              <span class="hp-sans text-xs flex-shrink-0" style="color:#b5936b">+</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ SERVICES — discrets -->
  <section style="background:#f7f5f2" class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8 text-center reveal" style="color:rgba(26,26,26,0.35)">Nos services</p>
      <div class="flex flex-wrap justify-center gap-3 stagger">
        {services.map(s => (
          <a href={s.href} class="hp-sans text-sm border px-6 py-3 hover:border-[#b5936b] hover:text-[#b5936b] transition-colors" style="border-color:rgba(26,26,26,0.12);color:rgba(26,26,26,0.6);text-decoration:none">
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ PREUVE -->
  <section style="background:#1a1a1a" class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 stagger">
        {[
          { num: '25', unit: ' ans', label: 'en finance internationale' },
          { num: '6',  unit: ' langues', label: '100% natifs spécialisés' },
          { num: '+40', unit: '', label: 'missions réalisées' },
          { num: 'NDA', unit: '', label: 'avant chaque mission' },
        ].map(s => (
          <div class="text-center">
            <p class="hp-serif text-3xl md:text-4xl font-light mb-2" style="color:#b5936b">{s.num}{s.unit}</p>
            <p class="hp-sans text-xs leading-snug" style="color:rgba(255,255,255,0.4)">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ CTA -->
  <section style="background:#f7f5f2" class="py-32 px-6 text-center">
    <div class="max-w-xl mx-auto reveal">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8" style="color:rgba(26,26,26,0.35)">Premier échange gratuit · Confidentiel</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light mb-6 leading-tight" style="color:#1a1a1a">
        Un projet international ?<br/><em class="italic" style="color:#b5936b">Parlons-en.</em>
      </h2>
      <p class="hp-sans text-base mb-12 max-w-sm mx-auto leading-[1.8]" style="color:rgba(26,26,26,0.45)">
        Décrivez-nous votre situation. Nous vous répondons sous 24h.
      </p>
      <a href="/fr/contact" class="hp-sans inline-block px-12 py-5 text-xs uppercase tracking-widest hover:opacity-80 transition-opacity" style="background:#b5936b;color:#1a1a1a;text-decoration:none">
        Nous contacter →
      </a>
    </div>
  </section>

  <script>
    // Situations toggle
    document.querySelectorAll('.sit-tile').forEach(function(tile) {
      tile.addEventListener('click', function() {
        var isOpen = tile.classList.contains('sit-open');
        document.querySelectorAll('.sit-tile').forEach(function(t) {
          t.classList.remove('sit-open');
          (t as HTMLElement).style.background = '#f7f5f2';
          (t as HTMLElement).style.borderColor = 'rgba(26,26,26,0.06)';
          var title = t.querySelector('.sit-title') as HTMLElement;
          if (title) title.style.color = '#1a1a1a';
          var detail = t.querySelector('.sit-detail') as HTMLElement;
          if (detail) detail.style.display = 'none';
          var plus = t.querySelector('span') as HTMLElement;
          if (plus) plus.textContent = '+';
        });
        if (!isOpen) {
          tile.classList.add('sit-open');
          (tile as HTMLElement).style.background = '#1a1a1a';
          (tile as HTMLElement).style.borderColor = '#b5936b';
          var title = tile.querySelector('.sit-title') as HTMLElement;
          if (title) title.style.color = 'white';
          var detail = tile.querySelector('.sit-detail') as HTMLElement;
          if (detail) detail.style.display = 'block';
          var plus = tile.querySelector('span') as HTMLElement;
          if (plus) plus.textContent = '−';
        }
      });
    });

    // Scroll reveal
    const io = new IntersectionObserver(e => e.forEach(x => {
      if (x.isIntersecting) { x.target.classList.add('in'); io.unobserve(x.target); }
    }), { threshold: 0.1 });
    document.querySelectorAll('.reveal, .stagger').forEach(el => io.observe(el));
  </script>
</Layout>
