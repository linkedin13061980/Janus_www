---
import Layout from '../../layouts/Layout.astro';

const locale = 'fr';
const currentPath = '/';

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JANUS Agence Linguistique",
  "description": "Agence linguistique B2B spécialisée franco-polonais à Lyon. Formation, interprétariat, accompagnement terrain, traduction.",
  "url": "https://agence-janus.fr",
  "telephone": "+33967056831",
  "email": "contact@agence-janus.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "20 ter rue Julien",
    "addressLocality": "Lyon",
    "postalCode": "69003",
    "addressCountry": "FR"
  },
  "areaServed": ["France", "Pologne"],
  "hasCredential": "Qualiopi",
  "foundingDate": "2021",
  "sameAs": ["https://www.linkedin.com/company/janus-agence-linguistique"]
};
---

<Layout
  title="JANUS Agence Linguistique | Formation, Interprétariat, Traduction | Lyon"
  description="Agence linguistique B2B à Lyon spécialisée franco-polonais. Formation Qualiopi, interprétariat, accompagnement terrain et traduction."
  locale={locale}
  currentPath={currentPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <!-- Hero -->
  <section class="bg-anthracite min-h-[92vh] flex flex-col justify-center px-6">
    <div class="max-w-3xl mx-auto w-full">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Lyon · Depuis 2021 · Qualiopi</p>
      <h1 class="text-5xl md:text-7xl font-serif font-light text-white leading-[1.1] mb-10">
        La langue<br/>comme outil<br/><em class="italic text-gold">de business.</em>
      </h1>
      <p class="text-white/50 text-lg max-w-md leading-relaxed mb-12">
        Formation, interprétariat et traduction pour les entreprises qui travaillent en français, anglais et polonais.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/fr/contact" class="inline-block px-8 py-4 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">
          Demander un devis
        </a>
        <a href="/fr/services" class="inline-block px-8 py-4 border border-white/20 text-white uppercase tracking-wider hover:border-gold hover:text-gold transition-colors text-sm">
          Nos services
        </a>
      </div>
    </div>
  </section>

  <!-- Ligne de confiance -->
  <div class="border-t border-b border-gold/15 py-8 px-6">
    <div class="max-w-3xl mx-auto flex flex-wrap gap-8 items-center">
      <span class="text-xs text-white/40 uppercase tracking-widest">Certifiée</span>
      <span class="text-sm text-gold font-medium">✓ Qualiopi #84692002569</span>
      <span class="text-white/15">|</span>
      <span class="text-xs text-white/40 uppercase tracking-widest">Éligible</span>
      <span class="text-sm text-white/70">CPF · OPCO · PDC</span>
      <span class="text-white/15">|</span>
      <span class="text-xs text-white/40 uppercase tracking-widest">NDA</span>
      <span class="text-sm text-white/70">Systématique</span>
    </div>
  </div>

  <!-- Services -->
  <section class="py-32 px-6 bg-anthracite">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-widest mb-6">Ce que nous faisons</p>
      <h2 class="text-4xl md:text-5xl font-serif font-light text-white mb-16 leading-tight">
        Quatre expertises.<br/>Un seul interlocuteur.
      </h2>
      <div class="divide-y divide-white/10">
        {[
          { num: '01', titre: 'Formation linguistique', detail: 'Anglais, polonais, français FLE — sur mesure, Qualiopi, financement CPF/OPCO.', href: '/fr/services' },
          { num: '02', titre: 'Interprétariat', detail: 'Consécutif et simultané. NDA signé avant chaque mission.', href: '/fr/services' },
          { num: '03', titre: 'Accompagnement terrain', detail: 'Présence physique sur site en France et en Pologne.', href: '/fr/services' },
          { num: '04', titre: 'Traduction', detail: 'Juridique, technique, commercial. Terminologie native.', href: '/fr/services' },
        ].map(s => (
          <a href={s.href} class="group flex items-start gap-8 py-8 hover:bg-white/[0.02] -mx-4 px-4 transition-colors">
            <span class="text-gold/30 font-serif text-sm pt-1 w-6 shrink-0">{s.num}</span>
            <div class="flex-1">
              <p class="text-white font-medium text-lg mb-1 group-hover:text-gold transition-colors">{s.titre}</p>
              <p class="text-white/40 text-sm">{s.detail}</p>
            </div>
            <span class="text-white/20 group-hover:text-gold transition-colors text-lg pt-0.5">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pologne -->
  <section class="py-32 px-6 bg-anthracite-light border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-widest mb-6">Opportunité</p>
      <h2 class="text-4xl md:text-5xl font-serif font-light text-white mb-6 leading-tight">
        La Pologne,<br/>6<sup class="text-2xl">e</sup> économie européenne.
      </h2>
      <p class="text-white/50 text-lg max-w-md leading-relaxed mb-12">
        35 milliards d'euros d'échanges franco-polonais en 2023. JANUS est votre interface culturelle et commerciale.
      </p>
      <a href="/fr/pologne-investir" class="inline-block px-8 py-4 border border-gold/40 text-gold uppercase tracking-wider hover:bg-gold hover:text-anthracite transition-colors text-sm font-medium">
        Découvrir nos services Pologne
      </a>
    </div>
  </section>

  <!-- CTA contact -->
  <section class="py-40 px-6 bg-anthracite text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-serif font-light text-white mb-6">
        Parlons de<br/><em class="italic text-gold">votre projet.</em>
      </h2>
      <p class="text-white/40 text-base mb-12">Réponse sous 24h. Premier échange gratuit et confidentiel.</p>
      <a href="/fr/contact" class="inline-block px-10 py-5 bg-gold text-anthracite font-semibold uppercase tracking-wider hover:bg-gold-light transition-colors text-sm">
        Nous contacter
      </a>
    </div>
  </section>

</Layout>
