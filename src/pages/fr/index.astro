---
import Layout from '../../layouts/Layout.astro';

const locale = 'fr';
const currentPath = '/';

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JANUS Agence Linguistique",
  "description": "Agence linguistique B2B multi-langues à Lyon. Formation, interprétariat, accompagnement terrain, traduction.",
  "url": "https://agence-janus.fr",
  "telephone": "+33967056831",
  "email": "contact@agence-janus.fr",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Lyon",
    "postalCode": "69003",
    "addressCountry": "FR"
  },
  "areaServed": ["France", "Pologne", "Royaume-Uni", "Allemagne", "Espagne", "Italie"],
  "hasCredential": "Qualiopi",
  "foundingDate": "2021",
  "sameAs": ["https://www.linkedin.com/company/janus-agence-linguistique"]
};
---

<Layout
  title="JANUS — Vos échanges internationaux, sécurisés | Lyon"
  description="Expert linguistique et interculturel pour vos négociations internationales. Formation, interprétariat, accompagnement terrain. Certifié Qualiopi. Lyon."
  locale={locale}
  currentPath={currentPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />

  <style is:global>
    .hp-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
    .hp-sans  { font-family: 'DM Sans', system-ui, sans-serif; }

    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <!-- ① HERO -->
  <section style="background:#f7f5f2" class="min-h-[94vh] flex flex-col justify-center px-6 py-28">
    <div class="max-w-3xl mx-auto w-full">
      <p class="hp-sans text-[#b5936b] text-xs uppercase tracking-[0.45em] mb-10 fade-up">
        Lyon · Négociation internationale · Qualiopi
      </p>
      <h1 class="hp-serif text-5xl md:text-7xl font-light text-[#1a1a1a] leading-[1.05] mb-10 fade-up">
        Vos échanges<br/>internationaux,<br/><em class="italic" style="color:#b5936b">sécurisés.</em>
      </h1>
      <p class="hp-sans text-[#1a1a1a]/50 text-lg max-w-md leading-[1.8] mb-14 fade-up">
        Un expert linguistique et interculturel à vos côtés pendant vos négociations critiques — pour que rien ne se perde en route.
      </p>
      <div class="flex flex-wrap gap-4 fade-up">
        <a
          href="mailto:contact@agence-janus.fr"
          class="hp-sans inline-block px-10 py-5 text-[#f7f5f2] font-medium uppercase tracking-widest text-sm transition-opacity hover:opacity-80"
          style="background:#b5936b"
        >
          Réserver un call
        </a>
        <a
          href="/fr/services"
          class="hp-sans inline-block px-10 py-5 border text-[#1a1a1a]/60 font-medium uppercase tracking-widest text-sm hover:border-[#b5936b] hover:text-[#b5936b] transition-colors"
          style="border-color:#1a1a1a30"
        >
          Nos services
        </a>
      </div>
    </div>
  </section>

  <!-- ② PROBLÈMES — 4 cartes -->
  <section class="bg-white py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="hp-sans text-[#1a1a1a]/35 text-xs uppercase tracking-[0.35em] mb-14 fade-up">Le problème</p>
      <div class="divide-y" style="border-color:#1a1a1a15">
        {[
          {
            n: '01',
            titre: 'Un terme mal traduit dans un contrat',
            desc: 'Clause de pénalité, condition de livraison, définition du périmètre — un mot ambigu dans la langue de l\'autre partie peut invalider des mois de négociation.',
          },
          {
            n: '02',
            titre: 'Un silence mal interprété',
            desc: 'En Pologne, en Allemagne, au Royaume-Uni — le silence ne signifie pas la même chose. Sans décodeur culturel, vous prenez une réserve pour un accord.',
          },
          {
            n: '03',
            titre: 'Une relation commerciale qui démarre mal',
            desc: 'Les premières réunions fondent la confiance. Une maladresse protocolaire ou un registre de langue inadapté crée une distance qui prend des mois à combler.',
          },
          {
            n: '04',
            titre: 'Des documents signés sans garantie de compréhension',
            desc: 'Vos partenaires ont-ils vraiment compris les obligations qu\'ils acceptent ? Un contrat validé dans une langue étrangère sans interprète expert reste un risque ouvert.',
          },
        ].map(p => (
          <div class="py-10 flex gap-8 fade-up">
            <span class="hp-serif text-[#b5936b]/30 text-sm w-6 shrink-0 pt-1">{p.n}</span>
            <div>
              <p class="hp-serif text-[#1a1a1a] text-xl mb-3">{p.titre}</p>
              <p class="hp-sans text-[#1a1a1a]/50 text-sm leading-[1.8] max-w-lg">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ③ SOLUTION -->
  <section style="background:#f7f5f2" class="py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="hp-sans text-[#1a1a1a]/35 text-xs uppercase tracking-[0.35em] mb-6 fade-up">La solution</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light text-[#1a1a1a] leading-tight mb-6 fade-up">
        Un expert à vos côtés,<br/>pas seulement un interprète.
      </h2>
      <p class="hp-sans text-[#1a1a1a]/55 text-lg leading-[1.8] max-w-xl mb-16 fade-up">
        JANUS ne traduit pas les mots — JANUS sécurise la communication dans sa globalité. Avant, pendant et après chaque échange critique.
      </p>
      <ul class="space-y-5 fade-up">
        {[
          'Préparation interculturelle ciblée avant chaque réunion',
          'Présence physique sur site — France, Pologne, Europe',
          'Interprétariat consécutif ou de liaison par des natifs spécialisés',
          'Lecture des signaux non-verbaux et décodage culturel en temps réel',
          'Compte-rendu détaillé et recommandations post-réunion',
          'NDA signé avant chaque mission, sans exception',
        ].map(item => (
          <li class="flex gap-4 hp-sans text-sm text-[#1a1a1a]/60 leading-[1.8]">
            <span style="color:#b5936b" class="shrink-0 mt-0.5">→</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ④ DEAL SPRINT -->
  <section style="background:#1a1a1a" class="py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="hp-sans text-[#b5936b] text-xs uppercase tracking-[0.35em] mb-6 fade-up">L'offre</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light text-white leading-tight mb-4 fade-up">
        Deal Sprint
      </h2>
      <p class="hp-serif text-[#b5936b] text-3xl font-light mb-10 fade-up">
        À partir de 800 € / jour
      </p>
      <p class="hp-sans text-white/45 text-lg leading-[1.8] max-w-xl mb-14 fade-up">
        Un forfait clair pour vos missions de négociation. Tout inclus : préparation, présence terrain, compte-rendu. NDA signé avant la mission.
      </p>
      <div class="divide-y mb-14 fade-up" style="border-color:#ffffff15">
        {[
          { item: 'Briefing de mission', detail: 'Analyse de votre contexte, de vos interlocuteurs et de vos objectifs. Préparation interculturelle ciblée.' },
          { item: 'Présence physique sur site', detail: 'Votre expert JANUS à vos côtés lors de chaque réunion. France, Pologne, Europe.' },
          { item: 'Interprétariat professionnel', detail: 'Consécutif ou liaison. FR ↔ PL · FR ↔ EN · FR ↔ DE et autres langues.' },
          { item: 'Compte-rendu de mission', detail: 'Rapport détaillé après chaque journée : points discutés, positions des parties, recommandations.' },
          { item: 'NDA systématique', detail: 'Accord de confidentialité signé avant chaque mission, sans exception.' },
        ].map(s => (
          <div class="py-6 flex gap-6">
            <span style="color:#b5936b" class="hp-sans text-sm shrink-0 mt-0.5">→</span>
            <div>
              <p class="hp-sans text-white text-sm font-medium mb-1">{s.item}</p>
              <p class="hp-sans text-white/35 text-sm leading-relaxed">{s.detail}</p>
            </div>
          </div>
        ))}
      </div>
      <a
        href="mailto:contact@agence-janus.fr"
        class="hp-sans inline-block px-10 py-5 text-[#1a1a1a] font-medium uppercase tracking-widest text-sm hover:opacity-80 transition-opacity fade-up"
        style="background:#b5936b"
      >
        Demander un devis Deal Sprint
      </a>
    </div>
  </section>

  <!-- ⑤ PREUVE 40H -->
  <section style="background:#f7f5f2" class="py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="hp-sans text-[#1a1a1a]/35 text-xs uppercase tracking-[0.35em] mb-12 fade-up">Mission récente</p>
      <h2 class="hp-serif text-4xl font-light text-[#1a1a1a] leading-tight mb-10 fade-up">
        40 heures.<br/>Un contrat signé.
      </h2>
      <div class="border-l-2 pl-8 py-2 mb-14 fade-up" style="border-color:#b5936b">
        <p class="hp-sans text-[#1a1a1a]/55 text-base leading-[1.8] max-w-lg">
          Une PME lyonnaise du secteur industriel souhaitait sécuriser un contrat de fourniture avec un partenaire polonais. Après deux échanges email infructueux, elle a fait appel à JANUS pour une mission de 5 jours : préparation interculturelle, 3 réunions à Katowice, traduction et validation du contrat final.
        </p>
      </div>
      <div class="grid grid-cols-3 gap-8 fade-up">
        {[
          { num: '40h', label: 'D\'accompagnement total' },
          { num: '3', label: 'Réunions négociées sur site' },
          { num: '−18%', label: 'Sur le prix initial fournisseur' },
        ].map(s => (
          <div>
            <p class="hp-serif text-4xl font-light mb-2" style="color:#b5936b">{s.num}</p>
            <p class="hp-sans text-[#1a1a1a]/45 text-xs leading-tight">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ DIFFÉRENCIATION -->
  <section class="bg-white py-28 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="hp-sans text-[#1a1a1a]/35 text-xs uppercase tracking-[0.35em] mb-6 fade-up">Pourquoi JANUS</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light text-[#1a1a1a] leading-tight mb-10 fade-up">
        13 ans en finance<br/>internationale.
      </h2>
      <p class="hp-sans text-[#1a1a1a]/55 text-lg leading-[1.8] max-w-xl mb-14 fade-up">
        Avant de fonder JANUS, Agata Mich a passé 13 ans dans des salles de négociation — SG CIB à Paris, Credit Suisse à Genève, Family Office en Suisse. Elle sait ce qui se joue quand les enjeux financiers sont élevés et les cultures, différentes.
      </p>
      <div class="divide-y fade-up" style="border-color:#1a1a1a10">
        {[
          { titre: 'Pas une agence de traduction', desc: 'JANUS ne livre pas des mots — JANUS vous aide à atteindre vos objectifs de négociation. La différence est fondamentale.' },
          { titre: 'Pas un interprète généraliste', desc: 'Nos experts comprennent la terminologie financière, juridique et industrielle. Ils ont travaillé dans ces secteurs avant d\'interpréter pour eux.' },
          { titre: 'Confidentialité absolue', desc: 'NDA signé avant chaque mission. Vos informations commerciales, vos chiffres et vos stratégies restent confidentiels.' },
        ].map(d => (
          <div class="py-8">
            <p class="hp-serif text-[#1a1a1a] text-lg mb-2">{d.titre}</p>
            <p class="hp-sans text-[#1a1a1a]/45 text-sm leading-[1.8] max-w-lg">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑦ CTA -->
  <section style="background:#1a1a1a" class="py-40 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <p class="hp-sans text-[#b5936b] text-xs uppercase tracking-[0.45em] mb-10 fade-up">Contact</p>
      <h2 class="hp-serif text-5xl md:text-6xl font-light text-white leading-[1.05] mb-8 fade-up">
        Une négociation<br/><em class="italic" style="color:#b5936b">à préparer ?</em>
      </h2>
      <p class="hp-sans text-white/35 text-base leading-[1.8] mb-14 max-w-md mx-auto fade-up">
        Décrivez votre mission en quelques lignes. Nous revenons vers vous sous 24h avec une proposition adaptée.
      </p>
      <a
        href="mailto:contact@agence-janus.fr"
        class="hp-sans inline-block px-12 py-6 text-[#1a1a1a] font-medium uppercase tracking-widest text-sm hover:opacity-80 transition-opacity mb-6 fade-up"
        style="background:#b5936b"
      >
        contact@agence-janus.fr
      </a>
      <p class="hp-sans text-white/20 text-xs mt-6 fade-up">Premier échange gratuit · NDA disponible avant toute discussion</p>
    </div>
  </section>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  </script>

</Layout>
