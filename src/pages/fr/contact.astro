---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
const locale = 'fr';
const currentPath = '/contact';
---
<Layout
  title="Contact | JANUS Agence Linguistique Lyon"
  description="Contactez JANUS pour un devis personnalisé. Formation, interprétariat, traduction franco-polonais. Réponse sous 24h."
  locale={locale}
  currentPath={currentPath}
>

  <section class="bg-anthracite pt-36 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">Contact</p>
      <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-[1.1] mb-6">
        Parlons de<br/><em class="italic text-gold">votre projet.</em>
      </h1>
      <p class="text-white/50 text-lg mb-16 max-w-md leading-relaxed">
        Réponse sous 24h. Devis gratuit. Premier échange confidentiel.
      </p>

      <!-- Coordonnées -->
      <div class="flex flex-col sm:flex-row gap-6 mb-20 pb-20 border-b border-white/10">
        <a href="tel:+33967056831" class="group flex items-center gap-3 text-white/50 hover:text-gold transition-colors">
          <span class="text-gold">→</span>
          <span class="text-sm">+33 9 67 05 68 31</span>
        </a>
        <a href="mailto:contact@agence-janus.fr" class="group flex items-center gap-3 text-white/50 hover:text-gold transition-colors">
          <span class="text-gold">→</span>
          <span class="text-sm">contact@agence-janus.fr</span>
        </a>
        <span class="flex items-center gap-3 text-white/30 text-sm">
          <span class="text-gold/40">→</span>
          20 ter rue Julien, Lyon 69003
        </span>
      </div>

      <!-- Formulaire -->
      <ContactForm locale={locale} />
    </div>
  </section>

</Layout>
