---
import Layout from '../../layouts/Layout.astro';
const locale = 'fr';
const currentPath = '/financement';
---
<Layout
  title="Financement des formations | JANUS Agence Linguistique Lyon"
  description="CPF, OPCO, PDC, France Travail — JANUS gère vos demandes de financement de A à Z. Formations linguistiques couvertes à 100% grâce au certificat Qualiopi."
  locale={locale}
  currentPath={currentPath}
>

  <!-- Hero -->
  <section class="bg-anthracite pt-36 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-[0.35em] mb-8">CPF · OPCO · PDC · France Travail</p>
      <h1 class="text-5xl md:text-6xl font-serif font-light text-white leading-[1.1] mb-8">
        Votre formation,<br/><em class="italic text-gold">financée.</em>
      </h1>
      <p class="text-white/50 text-lg max-w-lg leading-relaxed mb-10">
        Dans la plupart des cas, votre formation linguistique est couverte à 100%. JANUS gère vos demandes de A à Z.
      </p>
      <div class="flex items-center gap-4">
        <span class="px-3 py-1 border border-emerald-500 text-emerald-400 text-xs uppercase tracking-widest">✓ Qualiopi</span>
        <span class="text-white/40 text-sm">N° <strong class="text-white/60">84692002569</strong></span>
      </div>
    </div>
  </section>

  <!-- CPF -->
  <section class="py-24 px-6 border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-blue-400 text-xs uppercase tracking-widest mb-2">Pour les salariés et demandeurs d'emploi</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        CPF<span class="text-white/30 font-light"> — Compte Personnel de Formation</span>
      </h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Jusqu'à 1 500 € par an. Sans avance de frais, sans reste à charge dans la plupart des cas.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Disponible pour tous les salariés et demandeurs d\'emploi',
          'Certifications éligibles : TOEIC, TOEFL, DELE, Goethe, DELF, TCF',
          'Vérifiez votre solde sur moncompteformation.gouv.fr',
          'JANUS vous guide dans l\'inscription et le dossier',
          'FLE : CPF intégralement pris en charge pour salariés allophones bénéficiaires du CIR',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-blue-400 shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-blue-500/40 text-blue-400 uppercase tracking-wider hover:bg-blue-500/10 transition-colors text-sm">Vérifier mon éligibilité CPF</a>
    </div>
  </section>

  <!-- OPCO -->
  <section class="py-24 px-6 bg-anthracite-light border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-emerald-400 text-xs uppercase tracking-widest mb-2">Pour les entreprises</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        OPCO<span class="text-white/30 font-light"> — Opérateur de Compétences</span>
      </h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Prise en charge jusqu'à 100%. JANUS identifie votre OPCO et gère l'intégralité du dossier.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Prise en charge selon les règles de votre OPCO et secteur',
          'Toutes les formations JANUS sont éligibles (Qualiopi)',
          'JANUS identifie votre OPCO et gère la demande',
          'Délai habituel : 2 à 4 semaines',
          'Facturation directe à l\'OPCO possible dans certains cas',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-emerald-400 shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-emerald-600/40 text-emerald-400 uppercase tracking-wider hover:bg-emerald-500/10 transition-colors text-sm">Financer via mon OPCO</a>
    </div>
  </section>

  <!-- PDC -->
  <section class="py-24 px-6 border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold text-xs uppercase tracking-widest mb-2">Pour les employeurs</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        PDC<span class="text-white/30 font-light"> — Plan de Développement des Compétences</span>
      </h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        L'employeur finance la formation de ses salariés en heures de travail, salaire maintenu. Idéal pour les formations collectives en entreprise.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Formation en heures de travail, salaire maintenu',
          '100% financé par l\'employeur (récupérable via OPCO)',
          'Idéal pour les formations groupe intra-entreprise',
          'JANUS fournit tous les documents administratifs',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-gold shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-gold/40 text-gold uppercase tracking-wider hover:bg-gold hover:text-anthracite transition-colors text-sm">Former mes équipes</a>
    </div>
  </section>

  <!-- France Travail -->
  <section class="py-24 px-6 bg-anthracite-light border-t border-gold/10">
    <div class="max-w-3xl mx-auto">
      <p class="text-purple-400 text-xs uppercase tracking-widest mb-2">Pour les demandeurs d'emploi</p>
      <h2 class="text-4xl font-serif font-light text-white mb-6">
        France Travail
      </h2>
      <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-xl">
        Financement possible dans le cadre d'un projet professionnel défini avec votre conseiller.
      </p>
      <ul class="space-y-4 mb-12">
        {[
          'Sur validation de votre conseiller France Travail',
          'Doit s\'inscrire dans un projet professionnel défini',
          'Formations certifiantes privilégiées',
          'JANUS vous aide à préparer le dossier',
          'Allocations maintenues pendant la formation',
        ].map(item => (
          <li class="flex gap-4 text-white/55 text-sm">
            <span class="text-purple-400 shrink-0 mt-0.5">◆</span>{item}
          </li>
        ))}
      </ul>
      <a href="/fr/contact" class="inline-block px-8 py-4 border border-purple-500/40 text-purple-400 uppercase tracking-wider hover:bg-purple-500/10 transition-colors text-sm">Préparer mon dossier</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-40 px-6 bg-gold text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-4xl font-serif font-light text-anthracite mb-6">
        Votre formation peut être<br/><em class="italic">intégralement financée.</em>
      </h2>
      <p class="text-anthracite/60 text-base mb-12">Nous vérifions votre éligibilité gratuitement et constituons le dossier à votre place.</p>
      <a href="/fr/contact" class="inline-block px-10 py-5 bg-anthracite text-white font-semibold uppercase tracking-wider hover:bg-anthracite-light transition-colors text-sm">
        Vérifier mon financement
      </a>
    </div>
  </section>

</Layout>
