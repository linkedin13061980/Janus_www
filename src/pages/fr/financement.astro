---
import Layout from '../../layouts/Layout.astro';
const locale = 'fr';
const currentPath = '/financement';

const dispositifs = [
  {
    tag: 'Recommandé · Entreprises',
    titre: 'Plan de développement des compétences',
    desc: 'Financement direct par l\'entreprise. Aucun plafond, aucun reste à charge. Déductible fiscalement.',
    badge: 'Aucun reste à charge',
    featured: true,
  },
  {
    tag: 'PME < 50 salariés',
    titre: 'Financement OPCO',
    desc: 'Les OPCO financent les formations des entreprises de moins de 50 salariés. JANUS gère le dossier.',
    badge: 'Jusqu\'à 100%',
    featured: false,
  },
  {
    tag: 'Particuliers & salariés',
    titre: 'CPF individuel',
    desc: 'Jusqu\'à 1 500€ pour les certifications linguistiques. FLE pour salariés étrangers sans reste à charge.',
    badge: '1 500€ max',
    featured: false,
  },
];

const etapes = [
  { n: '01', titre: 'Audit gratuit', desc: 'Nous analysons votre situation et identifions le dispositif le plus avantageux.' },
  { n: '02', titre: 'Dossier JANUS', desc: 'Nous constituons et suivons l\'intégralité de votre dossier de financement.' },
  { n: '03', titre: 'Formation', desc: 'La formation démarre. Zéro administratif de votre côté.' },
  { n: '04', titre: 'Attestations', desc: 'Attestations Qualiopi, feuilles d\'émargement, bilan pédagogique livrés.' },
];
---

<Layout
  title="Financement Formation | JANUS Agence Linguistique Lyon"
  description="Vos formations linguistiques financées via OPCO, CPF ou plan de développement des compétences. JANUS gère le dossier pour vous."
  locale={locale}
  currentPath={currentPath}
>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />
  <style is:global>
    .hp-serif { font-family: 'Cormorant Garamond', Georgia, serif; }
    .hp-sans  { font-family: 'DM Sans', system-ui, sans-serif; }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .stagger > * { opacity: 0; transform: translateY(18px); transition: opacity .5s ease, transform .5s ease; }
    .stagger.in > *:nth-child(1) { opacity:1; transform:none; transition-delay:.05s }
    .stagger.in > *:nth-child(2) { opacity:1; transform:none; transition-delay:.15s }
    .stagger.in > *:nth-child(3) { opacity:1; transform:none; transition-delay:.25s }
    .stagger.in > *:nth-child(4) { opacity:1; transform:none; transition-delay:.35s }
  </style>

  <!-- HERO -->
  <section style="background:#f7f5f2" class="pt-36 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8 reveal" style="color:#b5936b">Financement</p>
      <h1 class="hp-serif text-5xl md:text-6xl font-light leading-[1.1] mb-6 reveal" style="color:#1a1a1a">
        Vos formations<br/><em class="italic" style="color:#b5936b">financées.</em>
      </h1>
      <p class="hp-sans text-lg max-w-lg leading-[1.8] reveal" style="color:rgba(26,26,26,0.5)">
        La partie formation de votre forfait JANUS peut être partiellement ou totalement prise en charge. Nous gérons le dossier pour vous.
      </p>
    </div>
  </section>

  <!-- DISPOSITIFS -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-14 text-center reveal" style="color:rgba(26,26,26,0.35)">Dispositifs disponibles</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px stagger" style="background:rgba(26,26,26,0.06)">
        {dispositifs.map(d => (
          <div class="p-10 flex flex-col gap-6" style={d.featured ? 'background:#1a1a1a' : 'background:white'}>
            <div>
              <p class="hp-sans text-[9px] uppercase tracking-[0.25em] mb-3" style="color:rgba(181,147,107,0.7)">{d.tag}</p>
              <p class="hp-serif text-2xl font-light mb-4 leading-snug" style={d.featured ? 'color:#b5936b' : 'color:#1a1a1a'}>{d.titre}</p>
              <p class="hp-sans text-sm leading-[1.7]" style={d.featured ? 'color:rgba(255,255,255,0.5)' : 'color:rgba(26,26,26,0.5)'}>{d.desc}</p>
            </div>
            <div class="mt-auto">
              <span class="hp-sans text-[10px] border px-4 py-2 rounded-full" style="color:rgba(181,147,107,0.8);border-color:rgba(181,147,107,0.3)">{d.badge}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ÉTAPES -->
  <section style="background:#f7f5f2" class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-14 text-center reveal" style="color:rgba(26,26,26,0.35)">Comment ça fonctionne</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px stagger" style="background:rgba(26,26,26,0.06)">
        {etapes.map(e => (
          <div class="bg-white p-8">
            <p class="hp-serif font-light mb-4" style="font-size:3rem;color:rgba(181,147,107,0.15)">{e.n}</p>
            <p class="hp-serif text-lg font-light mb-3" style="color:#1a1a1a">{e.titre}</p>
            <p class="hp-sans text-sm leading-[1.7]" style="color:rgba(26,26,26,0.5)">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#1a1a1a" class="py-32 px-6 text-center">
    <div class="max-w-xl mx-auto reveal">
      <p class="hp-sans text-xs uppercase tracking-[0.35em] mb-8" style="color:rgba(255,255,255,0.3)">Audit gratuit · Réponse sous 24h</p>
      <h2 class="hp-serif text-4xl md:text-5xl font-light text-white mb-6 leading-tight">
        Combien pouvez-vous<br/><em class="italic" style="color:#b5936b">obtenir ?</em>
      </h2>
      <a href="/fr/contact" class="hp-sans inline-block px-10 py-5 text-xs uppercase tracking-widest hover:opacity-80 transition-opacity" style="background:#b5936b;color:#1a1a1a">
        Calculer mon financement →
      </a>
    </div>
  </section>

  <script>
    const io = new IntersectionObserver(e => e.forEach(x => { if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target);} }), {threshold:0.1});
    document.querySelectorAll('.reveal,.stagger').forEach(el => io.observe(el));
  </script>
</Layout>
